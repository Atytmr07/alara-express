rules_version = '2';

// Storage security rules for Alara Balık Express product photos.
// - Anyone can READ images (they appear on the public menu).
// - Only signed-in admins on the allowlist can UPLOAD (≤5MB, images only).
//
// IMPORTANT: use the SAME admin e-mail(s) as in firestore.rules.

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'alara@alara.com'
        ];
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
